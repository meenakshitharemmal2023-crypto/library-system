import java.util.Scanner;
public class LibrarySystem {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter User Name: ");
        String userName = sc.nextLine();
        System.out.print("Enter User ID: ");
        int userId = sc.nextInt();
        System.out.print("Enter Number of Books Issued: ");
        int booksCount = sc.nextInt();
        System.out.print("Enter Days Borrowed: ");
        int days = sc.nextInt();
        int allowedDays = 14;
        int finePerDay = 5; 
        int totalFine = 0;
        if (days > allowedDays) {
            totalFine = (days - allowedDays) * finePerDay * booksCount;
        }
        System.out.println("\n--- User Details ---");
        System.out.println("Name: " + userName + " | ID: " + userId);
        System.out.println("Books Issued: " + booksCount);
        System.out.println("Total Fine: Rs. " + totalFine);
    }
}

